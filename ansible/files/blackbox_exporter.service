[Unit]
Description=Prometheus Blackbox Exporter
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/blackbox_exporter-0.27.0.linux-amd64
ExecStart=/home/ubuntu/blackbox_exporter-0.27.0.linux-amd64/blackbox_exporter \
  --config.file=/home/ubuntu/blackbox_exporter-0.27.0.linux-amd64/blackbox.yml
Restart=always

[Install]
WantedBy=multi-user.target